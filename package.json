{
  "name": "core-tukafe-api",
  "module": "src/app.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/app.ts",
    "start": "bun src/app.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bun run db:generate && bun run db:migrate",
    "db:seed": "bun scripts/seed-admin.ts",
    "db:studio": "bunx drizzle-kit studio",
    "auth:generate": "bunx @better-auth/cli@latest generate --config ./src/core/config/auth.config.ts",
    "auth:migrate": "bunx @better-auth/cli@latest migrate --config ./src/core/config/auth.config.ts",
    "scaffold": "bunx plop --plopfile scripts/scaffold/plopfile.mjs",
    "scaffold:feature": "bunx plop --plopfile scripts/scaffold/plopfile.mjs feature",
    "scaffold:action": "bunx plop --plopfile scripts/scaffold/plopfile.mjs action",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "better-auth": "^1.4.19",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "pg": "^8.18.0",
    "qs": "^6.15.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/qs": "^6.14.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "pino-pretty": "^13.1.3",
    "plop": "^4.0.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
